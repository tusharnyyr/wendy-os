# ==============================
# Wendy OS - Environment Variables
# ==============================

# ------------------------------
# Database Configuration
# ------------------------------
DATABASE_URL=postgresql://postgres:password@localhost:5432/wendy

# ------------------------------
# AI Provider Configuration
# ------------------------------
GROQ_API_KEY=your_groq_api_key_here

# ------------------------------
# Telegram Bot Configuration
# ------------------------------
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ------------------------------
# n8n Webhook Integration
# ------------------------------
N8N_WEBHOOK_URL=https://your-ngrok-or-production-url/webhook/wendy-events

# ------------------------------
# Cron Security Token
# Used for securing scheduled backend endpoints
# ------------------------------
WENDY_CRON_TOKEN=generate_secure_random_token_here

# ------------------------------
# Optional: Application Settings
# ------------------------------
APP_ENV=development
LOG_LEVEL=info